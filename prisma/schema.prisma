generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  role      String
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdLinks       SubmissionLink[] @relation("CreatedByUser")
  generatedContracts Contract[]       @relation("GeneratedByUser")
}

model Client {
  id          String   @id @default(uuid())
  clientCode  String?  @unique
  chineseName String
  englishName String
  phone       String?
  email       String?
  wechat      String?
  nationality String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cases Case[]
}

model Case {
  id                   String     @id @default(cuid())
  caseCode             String     @unique
  reference            String     @unique
  clientId             String
  serviceType          String
  country              String
  assignedConsultantId String?
  status               String
  contractStatus       String
  intakeStatus         String
  notes                String?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  client               Client     @relation(fields: [clientId], references: [id])
  assignedConsultant   AdminUser? @relation("CaseConsultant", fields: [assignedConsultantId], references: [id])

  submissionLinks      SubmissionLink[]
  submissions          DocumentSubmission[]
  documents            Document[]
  checklistItems       DocumentChecklistItem[]
  contracts            Contract[]
  auditLogs            AuditLog[]
}

model SubmissionLink {
  id          String   @id @default(uuid())
  caseId      String
  token       String   @unique
  status      String   @default("active")
  expiresAt   DateTime?
  maxUses     Int      @default(20)
  currentUses Int      @default(0)
  createdBy   String?
  createdAt   DateTime @default(now())

  case          Case                 @relation(fields: [caseId], references: [id])
  createdByUser User?                @relation("CreatedByUser", fields: [createdBy], references: [id])
  submissions   DocumentSubmission[]
}

model DocumentSubmission {
  id               String   @id @default(uuid())
  caseId           String
  submissionLinkId String?
  source           String   @default("portal")
  submittedByName  String?
  submittedByEmail String?
  status           String   @default("received")
  submittedAt      DateTime @default(now())
  remarks          String?

  case           Case            @relation(fields: [caseId], references: [id])
  submissionLink SubmissionLink? @relation(fields: [submissionLinkId], references: [id])
  documents      Document[]
}

model Document {
  id                 String   @id @default(uuid())
  caseId             String
  submissionId       String?
  checklistItemId    String?
  docType            String
  originalFilename   String
  normalizedFilename String?
  mimeType           String?
  fileSize           BigInt?
  displayName        String?
  versionNo          Int      @default(1)
  storageProvider    String   @default("temp")
  storagePath        String?
  storageUrl         String?
  reviewStatus       String   @default("uploaded")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  case       Case                @relation(fields: [caseId], references: [id])
  submission DocumentSubmission? @relation(fields: [submissionId], references: [id])
  checklistItem DocumentChecklistItem? @relation(fields: [checklistItemId], references: [id], onDelete: SetNull)
}

model DocumentChecklistItem {
  id          String   @id @default(cuid())
  caseId       String
  label       String
  description String?
  isRequired  Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  case      Case       @relation(fields: [caseId], references: [id])
  documents Document[]
}

model Contract {
  id           String   @id @default(uuid())
  caseId       String
  templateName String
  versionNo    Int      @default(1)
  generatedBy  String?
  filePath     String?
  fileUrl      String?
  pdfPath      String?
  pdfUrl       String?
  signedPdfPath String?
  signedPdfUrl String?
  signProvider String?
  signDeliveryMode String?
  signerName   String?
  signerEmail  String?
  providerDocumentId Int? @unique
  providerRecipientId Int?
  providerSigningToken String?
  providerSigningUrl String?
  providerDocumentStatus String?
  providerRecipientStatus String?
  signatureError String?
  status       String   @default("generated")
  generatedAt  DateTime @default(now())
  sentAt       DateTime?
  openedAt     DateTime?
  completedAt  DateTime?
  rejectedAt   DateTime?
  lastWebhookAt DateTime?

  case            Case  @relation(fields: [caseId], references: [id])
  generatedByUser User? @relation("GeneratedByUser", fields: [generatedBy], references: [id])
}

model AuditLog {
  id                String   @id @default(uuid())
  caseId            String?
  relatedEntityType String
  relatedEntityId   String?
  actionType        String
  actorType         String
  actorId           String?
  oldValue          Json?
  newValue          Json?
  metadata          Json?
  success           Boolean  @default(true)
  errorMessage      String?
  createdAt         DateTime @default(now())

  case Case? @relation(fields: [caseId], references: [id])
}

model AdminUser {
  id                String   @id @default(cuid())
  email             String   @unique
  name              String
  passwordHash      String
  role              String   @default("admin")
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  assignedCases     Case[]   @relation("CaseConsultant")
}
